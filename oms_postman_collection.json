				"type": "text/javascript",
				"exec": [
					"// Example of capturing order_id from Create Order response",
					"if (pm.response.code === 201) {",
					"    var jsonData = pm.response.json();",
					"    if (jsonData.id) {",
					"        pm.collectionVariables.set(\"order_id\", jsonData.id);",
					"    }",
					"}"
				]
			}
