							"mode": "raw",
							"raw": "{\n    \"customerName\": \"John Doe\",\n    \"items\": [\n        {\n            \"productId\": \"PROD-001\",\n            \"productName\": \"Mechanical Keyboard\",\n            \"quantity\": 1,\n            \"unitPrice\": 120.50\n        },\n        {\n            \"productId\": \"PROD-002\",\n            \"productName\": \"Gaming Mouse\",\n            \"quantity\": 2,\n            \"unitPrice\": 45.00\n        }\n    ]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/orders",
